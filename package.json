{
  "name": "doc-translator",
  "version": "1.0.0",
  "description": "A command line tool to translate markdown and MDX files using Claude AI",
  "type": "module",
  "main": "index.js",
  "bin": {
    "doc-translate": "bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "demo": "node bin/cli.js translate -i examples/StarRocksTest.md -l zh -s en",
    "setup": "node bin/cli.js setup",
    "languages": "node bin/cli.js languages",
    "lint": "eslint bin/**/*.js src/**/*.js",
    "test": "rm -f examples/StarRocksTest_zh.md && node bin/cli.js translate -i examples/StarRocksTest.md -l zh -s en"
  },
  "keywords": [
    "markdown",
    "docusaurus",
    "translation",
    "claude",
    "anthropic",
    "ai",
    "cli"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@playcanvas/eslint-config": "2.1.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "eslint": "^9.31.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.3",
    "globals": "^16.3.0",
    "ora": "^8.2.0",
    "path": "^0.12.7",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "publishConfig": {
    "@StarRocks:registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
